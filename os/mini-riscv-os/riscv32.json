{
  "llvm-target": "riscv32",
  "data-layout": "e-m:e-p:32:32-i64:64-n32-S128",
  "target-endian": "little",
  "target-pointer-width": "32",
  "target-c-int-width": "32",
  "arch": "riscv",
  "os": "none",
  "executables": true,
  "features": "+m,+a",
  "max-atomic-width": "32",
  "linker": "riscv64-unknown-elf-gcc",
  "linker-flavor": "gcc",
  "morestack": false,
  "position-independent-executables": false
}